# Supabase — both required. Anon key is safe to expose; service role key is NOT.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — required for /discover and AI travelogues
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o

# Web search — pick ONE. Without either, /discover still works but
# without source citations, and GPT will say so in budget_hint/local_tips.
SERPAPI_API_KEY=
BING_SEARCH_KEY=
