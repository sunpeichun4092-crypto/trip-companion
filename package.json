{
  "name": "tripmate",
  "version": "0.1.0",
  "private": true,
  "description": "TripMate · 旅程伴侣 — 3-8 人小团体出游伴侣（行前规划 / 行中管账 / 行后回忆）",
  "workspaces": [
    "apps/*",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:web":    "npm --workspace apps/web run dev",
    "build:web":  "npm --workspace apps/web run build",
    "build:shared": "npm --workspace packages/shared run build",
    "test": "npm --workspace packages/shared test && npm --workspace server test",
    "supabase:up": "supabase db push",
    "supabase:reset": "supabase db reset"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
